# Dictate Environment Configuration Example
# Copy this file to .env and fill in your values

# Transcription Provider Selection
# Choose between "mistral" (default), "groq" or "local"
TRANSCRIPTION_PROVIDER=mistral

# Mistral API Configuration (required when using Mistral provider)
MISTRAL_API_KEY=your-mistral-api-key-here
# Batch mode is off by default.
# false = Mistral realtime STT for normal keyboard shortcuts.
# true = opt out to whole-clip batch transcription with the normal endpoint.
BATCH_MODE=false

# Legacy override: auto, realtime, or batch
TRANSCRIPTION_MODE=auto

# Optional Mistral batch settings
MISTRAL_MODEL=voxtral-mini-latest
#MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Optional Mistral realtime WebSocket settings
MISTRAL_REALTIME_MODEL=voxtral-mini-transcribe-realtime-2602
MISTRAL_REALTIME_DELAY_MS=480
#MISTRAL_REALTIME_BASE_URL=wss://api.mistral.ai

# Groq API Configuration (required when using Groq provider)
#GROQ_API_KEY=your-groq-api-key-here
#GROQ_MODEL=whisper-large-v3-turbo
#GROQ_BASE_URL=https://api.groq.com/openai/v1

# Shared transcription settings
TRANSCRIPTION_LANGUAGE=auto
TRANSCRIPTION_TIMEOUT_SECONDS=60
TRANSCRIPTION_MAX_RETRIES=3

# Realtime output policy
# delta = type provider deltas immediately; stable = type finalized segments only.
REALTIME_OUTPUT_MODE=delta

# Context-aware editing is always on. REALTIME_OUTPUT_MODE=stable is recommended
# so realtime WebSocket correction commands are not typed as deltas first.
CONTEXT_EDITING_MAX_DELETE_CHARS=300
CONTEXT_EDITING_MAX_DELETE_WORDS=10
CONTEXT_EDITING_TYPE_REJECTED_COMMANDS=false

# Audio Feedback Configuration (optional - defaults shown)
ENABLE_AUDIO_FEEDBACK=true
BEEP_VOLUME=0.1

# Audio Configuration (optional - defaults shown)
AUDIO_BUFFER_DURATION_SECONDS=300
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Local Whisper Configuration (when TRANSCRIPTION_PROVIDER=local)
# Model files are stored in ~/.local/share/applications/dictate/models/
# Use `dictate --download-model` to fetch the model below
#WHISPER_MODEL=ggml-base.en.bin

# Logging Configuration (optional)
RUST_LOG=info
